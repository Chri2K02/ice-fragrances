STRIPE_SECRET_KEY=sk_test_xxx
# Public by design (shipped to the browser) — needed for embedded Checkout.
# Must be the same mode (test/live) as STRIPE_SECRET_KEY.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Better Auth (stood up alongside Clerk; not yet consuming). Generate a strong
# secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me
# Optional — only needed to override the request-derived origin (host-less SSR).
BETTER_AUTH_URL=
# Optional — pin the browser client's base URL (defaults to same-origin).
NEXT_PUBLIC_BETTER_AUTH_URL=
# Google OAuth (note the GOOGLE_OAUTH_* names). Authorized redirect URI:
#   https://www.icefragrances.com/api/auth/callback/google  (+ localhost for dev)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
